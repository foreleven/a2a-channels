{
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": [
      "ESNext"
    ],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@a2a-channels/core": [
        "./packages/core/src/index.ts"
      ],
      "@a2a-channels/domain": [
        "./packages/domain/src/index.ts"
      ],
      "@a2a-channels/event-store": [
        "./packages/event-store/src/index.ts"
      ],
      "@a2a-channels/agent-transport": [
        "./packages/agent-transport/src/index.ts"
      ],
      "@a2a-channels/openclaw-compat": [
        "./packages/openclaw-compat/src/index.ts"
      ],
      "@a2a-channels/channel-lark": [
        "./packages/channel-lark/src/index.ts"
      ],
      "@a2a-channels/store-sqlite": [
        "./packages/store-sqlite/src/index.ts"
      ]
    }
  },
  "exclude": [
    "apps/web",
    "node_modules"
  ]
}
