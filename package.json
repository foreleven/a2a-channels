{
  "name": "a2a-channels",
  "version": "0.1.0",
  "description": "Node.js gateway bridging messaging channel plugins with A2A agents",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "postinstall": "node scripts/patch-node-modules.js",
    "gateway": "node --env-file-if-exists .env --import tsx/esm apps/gateway/src/index.ts",
    "echo-agent": "node --import tsx/esm apps/echo-agent/src/index.ts",
    "web": "pnpm --filter @a2a-channels/web dev",
    "dev": "node --env-file-if-exists .env --import tsx/esm apps/gateway/src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "cd apps/gateway && DB_PATH=/tmp/test-a2a-store.db NODE_PATH=../../node_modules/.pnpm/node_modules node --import tsx/esm --test src/store/store.test.ts src/monitor-manager.test.ts"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.14",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "hono": "^4.12.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
