{
  "name": "agent-relay",
  "version": "0.1.0",
  "description": "Node.js gateway bridging messaging channel plugins with A2A agents",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "postinstall": "node scripts/patch-node-modules.js",
    "gateway": "make gateway",
    "seed": "make seed",
    "echo-agent": "node --import tsx/esm apps/echo-agent/src/index.ts",
    "web": "pnpm --filter @agent-relay/web dev",
    "dev": "node scripts/dev.mjs",
    "typecheck": "tsc --noEmit",
    "test": "make test"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.14",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "hono": "^4.12.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
