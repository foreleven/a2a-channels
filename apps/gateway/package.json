{
  "name": "@a2a-channels/gateway",
  "version": "0.1.0",
  "description": "A2A Channels Gateway – Hono HTTP server on Node.js",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file-if-exists ../../.env --import tsx/esm src/index.ts",
    "dev": "node --env-file-if-exists ../../.env --import tsx/esm src/index.ts",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "test": "XDG_CACHE_HOME=/tmp/a2a-cache DB_PATH=/tmp/test-a2a-store.db NODE_PATH=../../node_modules/.pnpm/node_modules node --import tsx/esm --test src/store/store.test.ts src/container/container.test.ts"
  },
  "dependencies": {
    "@a2a-channels/agent-transport": "workspace:*",
    "@a2a-channels/core": "workspace:*",
    "@a2a-channels/di": "workspace:*",
    "@a2a-channels/domain": "workspace:*",
    "@a2a-channels/event-store": "workspace:*",
    "@a2a-channels/openclaw-compat": "workspace:*",
    "@larksuite/openclaw-lark": "^2026.4.7",
    "@prisma/adapter-better-sqlite3": "7.7.0",
    "@prisma/client": "7.7.0",
    "@prisma/client-runtime-utils": "7.7.0",
    "inversify": "^7.7.1",
    "reflect-metadata": "^0.2.2",
    "openclaw": "^2026.4.15"
  },
  "devDependencies": {
    "prisma": "7.7.0"
  }
}
