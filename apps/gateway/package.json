{
  "name": "@a2a-channels/gateway",
  "version": "0.1.0",
  "description": "A2A Channels Gateway – Hono HTTP server on Node.js",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "make -C ../.. gateway",
    "dev": "make -C ../.. gateway-dev",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "node scripts/backfill-agent-config.mjs && prisma db push --schema=prisma/schema.prisma",
    "test": "make -C ../.. test"
  },
  "dependencies": {
    "@a2a-channels/agent-transport": "workspace:*",
    "@a2a-channels/domain": "workspace:*",
    "@a2a-channels/event-store": "workspace:*",
    "@a2a-channels/openclaw-compat": "workspace:*",
    "@openclaw/discord": "2026.5.2",
    "@openclaw/feishu": "2026.5.2",
    "@openclaw/qqbot": "2026.5.2",
    "@openclaw/weixin": "npm:@tencent-weixin/openclaw-weixin@2.3.1",
    "@openclaw/whatsapp": "2026.5.2",
    "@prisma/adapter-better-sqlite3": "7.7.0",
    "@prisma/client": "7.7.0",
    "@prisma/client-runtime-utils": "7.7.0",
    "better-sqlite3": "12.9.0",
    "inversify": "^7.7.1",
    "ioredis": "^5.10.1",
    "openclaw": "^2026.5.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "prisma": "7.7.0"
  }
}
