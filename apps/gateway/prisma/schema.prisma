// Gateway Prisma schema – SQLite backing store
// Run `prisma generate` after changes; use `prisma db push` to sync the schema.

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model ChannelBinding {
  id            String   @id @default(uuid())
  name          String
  channelType   String   @map("channel_type")
  accountId     String   @map("account_id")
  channelConfig String   @default("{}") @map("channel_config")
  agentUrl      String   @map("agent_url")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("channel_bindings")
}

model Agent {
  id          String   @id @default(uuid())
  name        String
  url         String
  protocol    String   @default("a2a")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("agents")
}

// ---------------------------------------------------------------------------
// Event sourcing – append-only event log
// ---------------------------------------------------------------------------

model Event {
  /// Auto-increment primary key – also used as the global sequence number for
  /// projection ordering (SQLite ROWID alias; always monotonically increasing).
  seq           Int      @id @default(autoincrement())

  /// UUID for idempotency / external references.
  uuid          String   @unique @default(uuid())

  /// Aggregate stream identifier, e.g. "ChannelBinding:some-uuid".
  streamId      String   @map("stream_id")

  /// 1-based position within the stream (for optimistic concurrency).
  streamVersion Int      @map("stream_version")

  /// Versioned event type discriminant, e.g. "ChannelBindingCreated.v1".
  eventType     String   @map("event_type")

  /// Serialised domain event payload (JSON).
  payload       String

  /// Serialised metadata (JSON).
  metadata      String

  occurredAt    DateTime @map("occurred_at")

  @@unique([streamId, streamVersion])
  @@index([streamId])
  @@map("events")
}

// ---------------------------------------------------------------------------
// Projection checkpoints
// ---------------------------------------------------------------------------

model ProjectionCheckpoint {
  /// Projection name, e.g. "ChannelBindingProjection".
  name String @id
  /// Last event seq that this projection has processed.
  seq  Int    @default(0)

  @@map("projection_checkpoints")
}
